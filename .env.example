# ===== Telegram Price Tracker Bot - configuración =====

# Token del bot, te lo da @BotFather en Telegram (OBLIGATORIO)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# IDs de Telegram autorizados a usar el bot, separados por comas.
# Si lo dejas vacío, CUALQUIERA puede usar el bot.
# Para saber tu ID escribe a @userinfobot en Telegram.
# Ejemplo: ALLOWED_USER_IDS=12345678,87654321
ALLOWED_USER_IDS=

# IDs de administradores (separados por comas). Solo ellos ven la opción
# "Consumo API", pueden usar /uso y reciben los avisos de cuota.
# Si lo dejas vacío, cualquier usuario autorizado lo ve (caso de un solo usuario).
# Cuando compartas el bot, pon aquí TU ID para que solo tú veas el consumo.
ADMIN_USER_IDS=

# Ruta del fichero de base de datos SQLite
DATABASE_PATH=data/price_tracker.db

# Hora del chequeo diario automático (formato 24h, hora del servidor)
DAILY_CHECK_HOUR=9
DAILY_CHECK_MINUTE=0

# Zona horaria para el scheduler (ej: Europe/Madrid)
TIMEZONE=Europe/Madrid

# Segundos de espera entre peticiones a tiendas (para no ir muy agresivo)
SCRAPE_DELAY_SECONDS=3

# Timeout de cada petición HTTP en segundos
HTTP_TIMEOUT=20

# Nivel de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO


# ===== API de scraping (ScraperAPI) para tiendas con anti-bot =====
# Necesaria para leer tiendas que bloquean al VPS (MediaMarkt, El Corte Inglés…).
# Consigue tu key gratis en https://www.scraperapi.com/ . Si lo dejas vacío,
# esas tiendas seguirán dando error 403 y el resto funcionará igual.
SCRAPERAPI_KEY=

# Dominios que se leerán a través de ScraperAPI (separados por comas).
SCRAPERAPI_DOMAINS=mediamarkt,fnac

# Presupuesto mensual de créditos (plan gratis = 1000).
SCRAPERAPI_MONTHLY_BUDGET=1000

# Créditos que cuesta cada petición (proxy residencial premium = 10).
SCRAPERAPI_CREDITS_PER_REQUEST=10

# Porcentaje de consumo al que avisarte (ej: 80 = aviso al llegar al 80%).
SCRAPERAPI_WARN_PERCENT=80
